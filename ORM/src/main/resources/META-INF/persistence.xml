<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="myPersistenceUnit">
        <!-- Entity classes -->
        <class>Domain.Customer</class>
        <class>Domain.Order</class>
        <class>Domain.Product</class>
        <class>Domain.OrderProduct</class>
        <properties>
            <!-- Database connection -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/SGBD"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="password"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <!-- Hibernate settings -->
            <property name="hibernate.connection.provider_class" value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>  <!-- this was added -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="false"/>  <!-- this was modified -->
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit></persistence>